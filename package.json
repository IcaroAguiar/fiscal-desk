{
  "name": "consulta-simples-csv",
  "version": "0.1.2",
  "description": "App desktop para validar enquadramento no Simples Nacional a partir de CSV.",
  "private": false,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:main\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsup src/main/main.ts src/main/preload.ts --format cjs --out-dir dist-electron --external electron --external playwright --external playwright-core --watch",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main.cjs && electronmon .",
    "build": "pnpm build:renderer && pnpm build:main",
    "build:renderer": "vite build",
    "build:main": "tsup src/main/main.ts src/main/preload.ts --format cjs --out-dir dist-electron --external electron --external playwright --external playwright-core",
    "build:browser": "npx playwright install chromium",
    "build:browser:win": "node scripts/ensure-playwright-browser.mjs win64 .playwright-browsers/win64",
    "postinstall": "npx playwright install chromium",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "tsx scripts/e2e-all.ts",
    "test:watch": "vitest",
    "compare:receita-web": "tsx scripts/compare-providers.ts",
    "perf:local-csv": "tsx scripts/perf-local-csv.ts",
    "smoke:real-csv": "tsx scripts/smoke-real-csv.ts",
    "smoke:electron-ui": "pnpm build && tsx scripts/smoke-electron-ui.ts",
    "smoke:visual": "tsx scripts/smoke-visual-ui.ts",
    "dist:mac": "pnpm build && pnpm build:browser && electron-builder --mac dmg --publish never",
    "dist:win": "pnpm build && pnpm build:browser:win && electron-builder --win nsis --x64 --publish never",
    "dist:win:arm64": "pnpm build && pnpm build:browser:win && electron-builder --win nsis --arm64 --publish never",
    "dist:dir": "pnpm build && electron-builder --dir --publish never",
    "repair:electron": "pnpm rebuild electron esbuild",
    "start": "electron ."
  },
  "dependencies": {
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "exceljs": "^4.4.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^24.6.0",
    "@types/yauzl": "^3.3.0",
    "@vitest/coverage-v8": "3.2.4",
    "concurrently": "^9.2.1",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "electronmon": "^2.0.3",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@2.0.2": "2.0.3"
    }
  }
}
